rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidDiagnostic(data) {
      return data.keys().hasAll(['analysis', 'timestamp', 'uid']) &&
             data.keys().size() == 3 &&
             data.analysis is string && data.analysis.size() <= 10000 &&
             data.uid is string && data.uid.size() <= 128 && data.uid == request.auth.uid;
    }

    match /diagnostics/{docId} {
      allow create: if isSignedIn() && isValidDiagnostic(incoming()) && incoming().timestamp == request.time;
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    match /device_sync/{docId} {
      allow read, write: if true;
    }
  }
}
