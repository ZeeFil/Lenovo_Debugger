{
    "layer": "top",
    "position": "top",
    "height": 40,
    "margin-top": 8,
    "margin-left": 16,
    "margin-right": 16,
    "margin-bottom": 0,
    "modules-left": [
        "sway/workspaces",
        "sway/mode"
    ],
    "modules-center": [
        "custom/foot",
        "custom/browser",
        "custom/close"
    ],
    "modules-right": [
        "memory",
        "network",
        "battery",
        "clock",
        "custom/reboot",
        "custom/power"
    ],
    "custom/foot": {
        "format": " Terminal",
        "on-click": "foot",
        "tooltip": false
    },
    "custom/browser": {
        "format": " Firefox",
        "on-click": "/home/user/browser_launch.sh",
        "tooltip": false
    },
    "custom/close": {
        "format": " Close",
        "on-click": "swaymsg kill",
        "tooltip": false
    },
    "memory": {
        "interval": 5,
        "format": " {percentage}% ({used:.1f}G)",
        "on-click": "python3 /home/user/ram_dropdown.py",
        "tooltip": false
    },
    "network": {
        "format-wifi": " {signalStrength}%",
        "format-ethernet": " {ipaddr}/{cidr}",
        "tooltip-format": "{ifname} via {gwaddr}",
        "format-linked": " No IP",
        "format-disconnected": " No Internet",
        "format-alt": " {ipaddr}/{cidr}"
    },
    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": " {capacity}%",
        "format-plugged": " {capacity}%",
        "format-alt": "{icon} {time}",
        "format-icons": ["", "", "", "", ""]
    },
    "clock": {
        "format": " {:%I:%M %p}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": " {:%Y-%m-%d}"
    },
    "custom/power": {
        "format": "⏻ Power",
        "on-click": "pkill swaynag; swaynag -t power -e bottom -f 'Inter 14' --background 1E1E2EFF --text CAD3F5FF --button-background 45475AFF --button-text CAD3F5FF --border 1E1E2EFF --border-bottom-size 0 --button-border-size 0 --button-padding 12 --button-gap 8 --button-dismiss-gap 8 --button-margin-right 0 --message-padding 8 -m '⏻ Power off the tablet?' -Z ' Yes, Power Off' 'loginctl poweroff' -s ' Cancel'",
        "tooltip": false
    },
    "custom/reboot": {
        "format": " Reboot",
        "on-click": "pkill swaynag; swaynag -t reboot -e bottom -f 'Inter 14' --background 1E1E2EFF --text CAD3F5FF --button-background 45475AFF --button-text CAD3F5FF --border 1E1E2EFF --border-bottom-size 0 --button-border-size 0 --button-padding 12 --button-gap 8 --button-dismiss-gap 8 --button-margin-right 0 --message-padding 8 -m ' Reboot the tablet?' -Z ' Yes, Reboot' 'loginctl reboot' -s ' Cancel'",
        "tooltip": false
    }
}
